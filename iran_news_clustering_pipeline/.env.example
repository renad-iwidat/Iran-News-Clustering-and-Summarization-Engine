DATABASE_HOST=your-database-host.render.com
DATABASE_PORT=5432
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password

# OpenAI API Keys - Iran News Project
OPENAI_API_KEY_IRAN_NEWS_TRANSLATION_HEBREW_ARABIC=sk-proj-your-key-here
OPENAI_API_KEY_IRAN_NEWS_CLUSTERING_ANALYSIS=sk-proj-your-key-here
OPENAI_API_KEY_IRAN_NEWS_REPORT_SUMMARIZATION=sk-proj-your-key-here

# OpenAI Models Configuration
OPENAI_MODEL_FOR_TRANSLATION=gpt-4o
OPENAI_MODEL_FOR_CLUSTERING=gpt-4o
OPENAI_MODEL_FOR_REPORT_GENERATION=gpt-4o

# Pipeline Configuration
PIPELINE_BATCH_SIZE=10
PIPELINE_RUN_INTERVAL_MINUTES=10
